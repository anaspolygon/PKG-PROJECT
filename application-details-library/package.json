    "next": ">=13.4.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-hook-form": "^7.71.2",
    "react-select": "^5.10.2"
  },
  "devDependencies": {
    "@radix-ui/react-slot": "^1.2.4",
